{
  "name": "ai-ticket",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "lefthook install",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "start": "pnpm -r start",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "check": "biome check --write --unsafe",
