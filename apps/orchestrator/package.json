{
  "name": "@ai-ticket/orchestrator",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "uv run fastapi dev src/main.py --port 8000",
    "build": "uv run ty check",
    "start": "uv run fastapi run src/main.py --port 8000",
    "check": "uv run ruff format . && uv run ruff check --fix .",
    "test": "uv run pytest",
    "clean": "rm -rf .pytest_cache .ruff_cache"
  }
}
